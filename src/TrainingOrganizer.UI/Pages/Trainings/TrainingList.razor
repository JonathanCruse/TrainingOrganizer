@page "/trainings"
@inject TrainingApiClient TrainingApi
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Trainings</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Trainings</MudText>
    <AuthorizeView Roles="Trainer,Admin">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            New Training
        </MudButton>
    </AuthorizeView>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_trainings is null || _trainings.Count == 0)
{
    <MudAlert Severity="Severity.Info">No trainings found.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var training in _trainings)
        {
            var pendingCount = training.Participants.Count(p => p.Status == ParticipationStatus.PendingApproval);
            var myParticipation = _currentMemberId.HasValue
                ? training.Participants.FirstOrDefault(p => p.MemberId == _currentMemberId.Value)
                : null;

            <MudItem xs="12" sm="6" md="4">
                <MudCard Style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/trainings/{training.Id}"))">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@training.Title</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <AuthorizeView Roles="Trainer,Admin">
                                    @if (pendingCount > 0)
                                    {
                                        <MudBadge Content="@pendingCount" Color="Color.Warning" Overlap="true">
                                            <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Small" />
                                        </MudBadge>
                                    }
                                </AuthorizeView>
                                <MudChip T="string" Color="@GetStatusColor(training.Status)" Size="Size.Small">
                                    @training.Status
                                </MudChip>
                            </MudStack>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-2">@training.Description</MudText>
                        <MudText Typo="Typo.caption">
                            @training.Start.LocalDateTime.ToString("g") — @training.End.LocalDateTime.ToString("g")
                        </MudText>
                        <MudText Typo="Typo.caption">
                            Participants: @training.ConfirmedParticipantCount / @training.MaxCapacity
                            @if (training.WaitlistCount > 0)
                            {
                                <text> (Waitlist: @training.WaitlistCount)</text>
                            }
                        </MudText>
                    </MudCardContent>
                    @if (training.Status == TrainingStatus.Published)
                    {
                        <MudCardActions @onclick:stopPropagation="true">
                            @if (myParticipation is null || myParticipation.Status == ParticipationStatus.Canceled)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => JoinTraining(training.Id))">
                                    Join
                                </MudButton>
                            }
                            else if (myParticipation.Status == ParticipationStatus.Confirmed)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.CheckCircle">
                                    Confirmed
                                </MudChip>
                            }
                            else if (myParticipation.Status == ParticipationStatus.Waitlisted)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                    Waitlist #@myParticipation.WaitlistPosition
                                </MudChip>
                            }
                            else if (myParticipation.Status == ParticipationStatus.PendingApproval)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.PendingActions">
                                    Awaiting approval
                                </MudChip>
                            }
                        </MudCardActions>
                    }
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<TrainingResponse>? _trainings;
    private string? _error;
    private bool _loading = true;
    private Guid? _currentMemberId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var memberIdClaim = authState.User.FindFirst("member_id")?.Value;
        if (memberIdClaim is not null && Guid.TryParse(memberIdClaim, out var id))
            _currentMemberId = id;

        await LoadTrainings();
    }

    private async Task LoadTrainings()
    {
        _loading = true;
        _error = null;

        try
        {
            var result = await TrainingApi.GetAllAsync();
            _trainings = result?.Items.ToList();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load trainings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task JoinTraining(Guid id)
    {
        try
        {
            await TrainingApi.JoinAsync(id);
            await LoadTrainings();
        }
        catch (Exception ex)
        {
            _error = $"Failed to join: {ex.Message}";
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateTrainingDialog>(string.Empty, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTrainings();
        }
    }

    private static Color GetStatusColor(TrainingStatus status) => status switch
    {
        TrainingStatus.Published => Color.Success,
        TrainingStatus.Draft => Color.Default,
        TrainingStatus.Canceled => Color.Error,
        TrainingStatus.Completed => Color.Info,
        _ => Color.Default
    };
}
