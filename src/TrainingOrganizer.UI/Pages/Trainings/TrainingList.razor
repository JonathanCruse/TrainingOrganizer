@page "/trainings"
@inject TrainingApiClient TrainingApi
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Trainings</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Trainings</MudText>
    <AuthorizeView Roles="Trainer,Admin">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            New Training
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudStack Row="true" Spacing="2" Class="mb-4" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
    <MudTextField @bind-Value="_search" Label="Search" Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true" Immediate="false" DebounceInterval="400"
                  TextChanged="OnSearchChanged" Style="min-width: 220px;" />
    <MudSelect T="TrainingStatus?" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense"
               Value="_statusFilter" ValueChanged="OnStatusChanged" Clearable="true" Style="min-width: 160px;">
        @foreach (var s in Enum.GetValues<TrainingStatus>())
        {
            <MudSelectItem T="TrainingStatus?" Value="@s">@s</MudSelectItem>
        }
    </MudSelect>
    <MudDatePicker Label="From" Date="_fromDate" Clearable="true" Variant="Variant.Outlined"
                   Margin="Margin.Dense" DateChanged="OnFromDateChanged" />
    <MudDatePicker Label="To" Date="_toDate" Clearable="true" Variant="Variant.Outlined"
                   Margin="Margin.Dense" DateChanged="OnToDateChanged" />
    <MudToggleIconButton Toggled="_availableOnly"
                         Icon="@Icons.Material.Filled.FilterAlt"
                         ToggledIcon="@Icons.Material.Filled.FilterAlt"
                         Color="Color.Default" ToggledColor="Color.Primary"
                         Size="Size.Medium" ToggledSize="Size.Medium"
                         title="Show available only"
                         ToggledChanged="OnAvailableToggled" />
    @if (HasActiveFilters)
    {
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilters">
            Clear filters
        </MudButton>
    }
</MudStack>

@if (HasActiveFilters)
{
    <MudStack Row="true" Spacing="1" Class="mb-3" Wrap="Wrap.Wrap">
        @if (!string.IsNullOrWhiteSpace(_search))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _search = null; _ = LoadTrainings(); }">
                Search: @_search
            </MudChip>
        }
        @if (_statusFilter.HasValue)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _statusFilter = null; _ = LoadTrainings(); }">
                Status: @_statusFilter
            </MudChip>
        }
        @if (_fromDate.HasValue)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _fromDate = null; _ = LoadTrainings(); }">
                From: @_fromDate.Value.ToString("d")
            </MudChip>
        }
        @if (_toDate.HasValue)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _toDate = null; _ = LoadTrainings(); }">
                To: @_toDate.Value.ToString("d")
            </MudChip>
        }
        @if (_availableOnly)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _availableOnly = false; _ = LoadTrainings(); }">
                Available only
            </MudChip>
        }
    </MudStack>
}

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_displayedTrainings is null || _displayedTrainings.Count == 0)
{
    <MudAlert Severity="Severity.Info">No trainings found.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var training in _displayedTrainings)
        {
            var pendingCount = training.Participants.Count(p => p.Status == ParticipationStatus.PendingApproval);
            var myParticipation = _currentMemberId.HasValue
                ? training.Participants.FirstOrDefault(p => p.MemberId == _currentMemberId.Value)
                : null;

            <MudItem xs="12" sm="6" md="4">
                <MudCard Style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/trainings/{training.Id}"))">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@training.Title</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <AuthorizeView Roles="Trainer,Admin">
                                    @if (pendingCount > 0)
                                    {
                                        <MudBadge Content="@pendingCount" Color="Color.Warning" Overlap="true">
                                            <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Small" />
                                        </MudBadge>
                                    }
                                </AuthorizeView>
                                <MudChip T="string" Color="@GetStatusColor(training.Status)" Size="Size.Small">
                                    @training.Status
                                </MudChip>
                            </MudStack>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-2">@training.Description</MudText>
                        <MudText Typo="Typo.caption">
                            @training.Start.LocalDateTime.ToString("g") — @training.End.LocalDateTime.ToString("g")
                        </MudText>
                        <MudText Typo="Typo.caption">
                            Participants: @training.ConfirmedParticipantCount / @training.MaxCapacity
                            @if (training.WaitlistCount > 0)
                            {
                                <text> (Waitlist: @training.WaitlistCount)</text>
                            }
                        </MudText>
                    </MudCardContent>
                    @if (training.Status == TrainingStatus.Published)
                    {
                        <MudCardActions @onclick:stopPropagation="true">
                            @if (myParticipation is null || myParticipation.Status == ParticipationStatus.Canceled)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => JoinTraining(training.Id))">
                                    Join
                                </MudButton>
                            }
                            else if (myParticipation.Status == ParticipationStatus.Confirmed)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.CheckCircle">
                                    Confirmed
                                </MudChip>
                            }
                            else if (myParticipation.Status == ParticipationStatus.Waitlisted)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                    Waitlist #@myParticipation.WaitlistPosition
                                </MudChip>
                            }
                            else if (myParticipation.Status == ParticipationStatus.PendingApproval)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.PendingActions">
                                    Awaiting approval
                                </MudChip>
                            }
                        </MudCardActions>
                    }
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<TrainingResponse>? _trainings;
    private List<TrainingResponse>? _displayedTrainings;
    private string? _error;
    private bool _loading = true;
    private Guid? _currentMemberId;

    private string? _search;
    private TrainingStatus? _statusFilter;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private bool _availableOnly;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_search) || _statusFilter.HasValue
        || _fromDate.HasValue || _toDate.HasValue || _availableOnly;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var memberIdClaim = authState.User.FindFirst("member_id")?.Value;
        if (memberIdClaim is not null && Guid.TryParse(memberIdClaim, out var id))
            _currentMemberId = id;

        await LoadTrainings();
    }

    private async Task LoadTrainings()
    {
        _loading = true;
        _error = null;

        try
        {
            DateTimeOffset? from = _fromDate.HasValue ? new DateTimeOffset(_fromDate.Value, TimeSpan.Zero) : null;
            DateTimeOffset? to = _toDate.HasValue ? new DateTimeOffset(_toDate.Value.AddDays(1), TimeSpan.Zero) : null;

            var result = await TrainingApi.GetAllAsync(
                status: _statusFilter?.ToString(), search: _search, from: from, to: to);
            _trainings = result?.Items.ToList();
            ApplyClientFilters();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load trainings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyClientFilters()
    {
        if (_trainings is null)
        {
            _displayedTrainings = null;
            return;
        }

        var filtered = _trainings.AsEnumerable();

        if (_availableOnly)
        {
            filtered = filtered.Where(t =>
                t.Status == TrainingStatus.Published
                && t.ConfirmedParticipantCount < t.MaxCapacity);
        }

        _displayedTrainings = filtered.ToList();
    }

    private async Task OnSearchChanged(string? value)
    {
        _search = value;
        await LoadTrainings();
    }

    private async Task OnStatusChanged(TrainingStatus? value)
    {
        _statusFilter = value;
        await LoadTrainings();
    }

    private async Task OnFromDateChanged(DateTime? value)
    {
        _fromDate = value;
        await LoadTrainings();
    }

    private async Task OnToDateChanged(DateTime? value)
    {
        _toDate = value;
        await LoadTrainings();
    }

    private async Task OnAvailableToggled(bool value)
    {
        _availableOnly = value;
        ApplyClientFilters();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        _search = null;
        _statusFilter = null;
        _fromDate = null;
        _toDate = null;
        _availableOnly = false;
        await LoadTrainings();
    }

    private async Task JoinTraining(Guid id)
    {
        try
        {
            var response = await TrainingApi.JoinAsync(id);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Joined training.", Severity.Success);
                await LoadTrainings();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to join: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateTrainingDialog>(string.Empty, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadTrainings();
        }
    }

    private static Color GetStatusColor(TrainingStatus status) => status switch
    {
        TrainingStatus.Published => Color.Success,
        TrainingStatus.Draft => Color.Default,
        TrainingStatus.Canceled => Color.Error,
        TrainingStatus.Completed => Color.Info,
        _ => Color.Default
    };
}
