@inject RecurringTrainingApiClient RecurringTrainingApi
@inject MemberApiClient MemberApi

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Create Recurring Training</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_title" Label="Title" Required="true"
                          RequiredError="Title is required" Class="mb-3" />
            <MudTextField @bind-Value="_description" Label="Description" Lines="3" Class="mb-3" />
            <MudSelect @bind-Value="_pattern" Label="Pattern" Required="true" Class="mb-3">
                @foreach (var p in Enum.GetValues<RecurrencePattern>())
                {
                    <MudSelectItem Value="p">@p</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="_dayOfWeek" Label="Day of Week" Required="true" Class="mb-3">
                @foreach (var d in Enum.GetValues<DayOfWeek>())
                {
                    <MudSelectItem Value="d">@d</MudSelectItem>
                }
            </MudSelect>
            <MudTimePicker @bind-Time="_timeOfDay" Label="Time of Day" Required="true"
                           RequiredError="Time is required" Class="mb-3" />
            <MudTimePicker @bind-Time="_duration" Label="Duration" Required="true"
                           RequiredError="Duration is required" Class="mb-3" />
            <MudDatePicker @bind-Date="_startDate" Label="Start Date" Required="true"
                           RequiredError="Start date is required" Class="mb-3" />
            <MudDatePicker @bind-Date="_endDate" Label="End Date (optional)" Class="mb-3" />
            <MudNumericField @bind-Value="_minCapacity" Label="Min Capacity" Min="1" Required="true"
                             RequiredError="Min capacity is required" Class="mb-3" />
            <MudNumericField @bind-Value="_maxCapacity" Label="Max Capacity" Min="1" Required="true"
                             RequiredError="Max capacity is required" Class="mb-3" />
            <MudSelect @bind-Value="_visibility" Label="Visibility" Required="true" Class="mb-3">
                @foreach (var v in Enum.GetValues<Visibility>())
                {
                    <MudSelectItem Value="v">@v</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="Guid" Label="Trainers" MultiSelection="true" @bind-SelectedValues="_selectedTrainerIds"
                       Required="true" RequiredError="At least one trainer is required" Class="mb-3"
                       ToStringFunc="@(id => _trainerLookup.GetValueOrDefault(id, id.ToString()))">
                @foreach (var trainer in _trainers)
                {
                    <MudSelectItem T="Guid" Value="trainer.Id">@trainer.FirstName @trainer.LastName</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(!_isValid || _submitting)">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private bool _isValid;
    private bool _submitting;
    private string? _error;

    private string _title = string.Empty;
    private string? _description;
    private RecurrencePattern _pattern = RecurrencePattern.Weekly;
    private DayOfWeek _dayOfWeek = DayOfWeek.Monday;
    private TimeSpan? _timeOfDay = new(18, 0, 0);
    private TimeSpan? _duration = new(1, 0, 0);
    private DateTime? _startDate = DateTime.Today;
    private DateTime? _endDate;
    private int _minCapacity = 1;
    private int _maxCapacity = 20;
    private Visibility _visibility = Visibility.Public;

    private List<MemberResponse> _trainers = [];
    private IReadOnlyCollection<Guid> _selectedTrainerIds = [];
    private Dictionary<Guid, string> _trainerLookup = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await MemberApi.GetAllAsync(1, 100);
            if (result?.Items is not null)
            {
                _trainers = result.Items
                    .Where(m => m.Roles.Contains(MemberRole.Trainer) || m.Roles.Contains(MemberRole.Admin))
                    .Where(m => m.Status == RegistrationStatus.Approved)
                    .ToList();
                _trainerLookup = _trainers.ToDictionary(t => t.Id, t => $"{t.FirstName} {t.LastName}");
            }
        }
        catch
        {
            // Trainer list load failure is non-fatal
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _submitting = true;
        _error = null;

        try
        {
            var request = new CreateRecurringTrainingRequest(
                _title,
                _description,
                _minCapacity,
                _maxCapacity,
                _visibility.ToString(),
                _selectedTrainerIds.ToList(),
                _pattern.ToString(),
                _dayOfWeek,
                _timeOfDay!.Value.ToString(@"hh\:mm"),
                _duration!.Value.ToString(@"hh\:mm"),
                _startDate!.Value.ToString("yyyy-MM-dd"),
                _endDate?.ToString("yyyy-MM-dd"));

            var response = await RecurringTrainingApi.CreateAsync(request);
            if (response.IsSuccessStatusCode)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = $"Failed to create recurring training: {body}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to create recurring training: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
