@page "/trainings/{Id:guid}"
@attribute [Authorize]
@inject TrainingApiClient TrainingApi
@inject MemberApiClient MemberApi
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_training?.Title ?? "Training")</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_training is null)
{
    <MudAlert Severity="Severity.Warning">Training not found.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
                   OnClick="@(() => Nav.NavigateTo("/trainings"))">
            Back
        </MudButton>
        <AuthorizeView Roles="Trainer,Admin">
            <MudStack Row="true" Spacing="1">
                @if (_training.Status == TrainingStatus.Draft)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               OnClick="PublishTraining" Disabled="_actioning">
                        Publish
                    </MudButton>
                }
                @if (_training.Status == TrainingStatus.Published)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                               OnClick="CompleteTraining" Disabled="_actioning">
                        Complete
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="CancelTraining" Disabled="_actioning">
                        Cancel
                    </MudButton>
                }
            </MudStack>
        </AuthorizeView>
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.h4">@_training.Title</MudText>
        <MudChip T="string" Color="@GetStatusColor(_training.Status)" Size="Size.Small">@_training.Status</MudChip>
        <MudChip T="string" Color="Color.Default" Size="Size.Small">@_training.Visibility</MudChip>
    </MudStack>

    <MudStack Row="true" Spacing="4" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
            <MudText Typo="Typo.body2">
                @_training.Start.LocalDateTime.ToString("ddd, MMM d · HH:mm") — @_training.End.LocalDateTime.ToString("HH:mm")
            </MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" />
            <MudText Typo="Typo.body2">
                @_training.ConfirmedParticipantCount / @_training.MaxCapacity confirmed
                @if (_training.WaitlistCount > 0)
                {
                    <text> · @_training.WaitlistCount on waitlist</text>
                }
                @if (_pendingCount > 0)
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-1">
                        @_pendingCount pending
                    </MudChip>
                }
            </MudText>
        </MudStack>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_training.Description))
    {
        <MudText Typo="Typo.body1" Class="mb-4">@_training.Description</MudText>
    }

    @* Join / Leave / Status for current user *@
    @if (_training.Status == TrainingStatus.Published)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            @if (_myParticipation is null || _myParticipation.Status == ParticipationStatus.Canceled)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="JoinTraining" Disabled="_actioning">
                    Join Training
                </MudButton>
            }
            else if (_myParticipation.Status == ParticipationStatus.Confirmed)
            {
                <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                    You are confirmed
                </MudChip>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="LeaveTraining" Disabled="_actioning">
                    Leave
                </MudButton>
            }
            else if (_myParticipation.Status == ParticipationStatus.Waitlisted)
            {
                <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.HourglassTop">
                    Waitlist position @_myParticipation.WaitlistPosition
                </MudChip>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="LeaveTraining" Disabled="_actioning">
                    Leave Waitlist
                </MudButton>
            }
            else if (_myParticipation.Status == ParticipationStatus.PendingApproval)
            {
                <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.PendingActions">
                    Awaiting approval
                </MudChip>
            }
        </MudStack>
    }

    @* Pending approval — Admin/Trainer only *@
    <AuthorizeView Roles="Trainer,Admin">
        @if (_pendingParticipants.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mb-2">
                Pending Approval
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">@_pendingParticipants.Count</MudChip>
            </MudText>
            <MudTable Items="_pendingParticipants" Hover="true" Dense="true" Class="mb-4">
                <HeaderContent>
                    <MudTh>Member</MudTh>
                    <MudTh>Requested</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate Context="p">
                    <MudTd DataLabel="Member">@GetMemberName(p.MemberId)</MudTd>
                    <MudTd DataLabel="Requested">@p.JoinedAt.LocalDateTime.ToString("g")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                                       Size="Size.Small" title="Accept"
                                       OnClick="@(() => AcceptParticipant(p.MemberId))"
                                       Disabled="_actioning" />
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                                       Size="Size.Small" title="Reject"
                                       OnClick="@(() => RejectParticipant(p.MemberId))"
                                       Disabled="_actioning" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </AuthorizeView>

    @* Confirmed participants *@
    @if (_confirmedParticipants.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Confirmed (@_confirmedParticipants.Count)</MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-4">
            @foreach (var p in _confirmedParticipants)
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">
                    @GetMemberName(p.MemberId)
                </MudChip>
            }
        </MudStack>
    }

    @* Waitlisted participants *@
    @if (_waitlistedParticipants.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Waitlist (@_waitlistedParticipants.Count)</MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-4">
            @foreach (var p in _waitlistedParticipants.OrderBy(p => p.WaitlistPosition))
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                    #@p.WaitlistPosition @GetMemberName(p.MemberId)
                </MudChip>
            }
        </MudStack>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    [Parameter] public Guid Id { get; set; }

    private TrainingResponse? _training;
    private bool _loading = true;
    private bool _actioning;
    private string? _error;

    private Guid? _currentMemberId;
    private bool _isTrainerOrAdmin;
    private ParticipantResponse? _myParticipation;

    private List<ParticipantResponse> _pendingParticipants = [];
    private List<ParticipantResponse> _confirmedParticipants = [];
    private List<ParticipantResponse> _waitlistedParticipants = [];
    private int _pendingCount;

    private Dictionary<Guid, string> _memberNames = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var memberIdClaim = authState.User.FindFirst("member_id")?.Value;
        if (memberIdClaim is not null && Guid.TryParse(memberIdClaim, out var id))
            _currentMemberId = id;

        _isTrainerOrAdmin = authState.User.IsInRole("Trainer") || authState.User.IsInRole("Admin");

        await LoadTraining();

        if (_isTrainerOrAdmin)
            await LoadMemberNames();
    }

    private async Task LoadTraining()
    {
        _loading = true;
        _error = null;

        try
        {
            _training = await TrainingApi.GetByIdAsync(Id);
            UpdateParticipantLists();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load training: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void UpdateParticipantLists()
    {
        if (_training is null) return;

        _myParticipation = _currentMemberId.HasValue
            ? _training.Participants.FirstOrDefault(p => p.MemberId == _currentMemberId.Value)
            : null;

        _pendingParticipants = _training.Participants
            .Where(p => p.Status == ParticipationStatus.PendingApproval).ToList();
        _confirmedParticipants = _training.Participants
            .Where(p => p.Status == ParticipationStatus.Confirmed).ToList();
        _waitlistedParticipants = _training.Participants
            .Where(p => p.Status == ParticipationStatus.Waitlisted).ToList();
        _pendingCount = _pendingParticipants.Count;
    }

    private async Task LoadMemberNames()
    {
        try
        {
            var result = await MemberApi.GetAllAsync(1, 200);
            if (result?.Items is not null)
                _memberNames = result.Items.ToDictionary(m => m.Id, m => $"{m.FirstName} {m.LastName}");
        }
        catch
        {
            // Non-fatal — fall back to IDs
        }
    }

    private string GetMemberName(Guid memberId)
        => _memberNames.TryGetValue(memberId, out var name) ? name : memberId.ToString()[..8] + "…";

    private async Task JoinTraining()
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.JoinAsync(Id);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Joined successfully.", Severity.Success);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to join: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task LeaveTraining()
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.LeaveAsync(Id);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Left training.", Severity.Info);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to leave: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task AcceptParticipant(Guid memberId)
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.AcceptParticipantAsync(Id, memberId);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Participant accepted.", Severity.Success);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to accept: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task RejectParticipant(Guid memberId)
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.RejectParticipantAsync(Id, memberId);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Participant rejected.", Severity.Info);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to reject: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task PublishTraining()
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.PublishAsync(Id);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Training published.", Severity.Success);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to publish: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task CompleteTraining()
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.CompleteAsync(Id);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Training completed.", Severity.Success);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to complete: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task CancelTraining()
    {
        _actioning = true;
        try
        {
            var response = await TrainingApi.CancelAsync(Id, new CancelTrainingRequest("Canceled by trainer/admin"));
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Training canceled.", Severity.Warning);
                await LoadTraining();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to cancel: {body}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actioning = false;
        }
    }

    private static Color GetStatusColor(TrainingStatus status) => status switch
    {
        TrainingStatus.Published => Color.Success,
        TrainingStatus.Draft => Color.Default,
        TrainingStatus.Canceled => Color.Error,
        TrainingStatus.Completed => Color.Info,
        _ => Color.Default
    };
}
