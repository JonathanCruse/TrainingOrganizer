@inject FacilityApiClient FacilityApi

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Create Manual Booking</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudSelect T="Guid?" Value="_selectedLocationId" Label="Location" Required="true"
                       RequiredError="Location is required" Class="mb-3"
                       AnchorOrigin="Origin.BottomCenter" ValueChanged="OnLocationChanged">
                @foreach (var loc in Locations)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)loc.Id)">@loc.Name</MudSelectItem>
                }
            </MudSelect>
            @if (_selectedLocationId.HasValue)
            {
                <MudSelect T="Guid?" Value="_selectedRoomId" Label="Room" Required="true"
                           RequiredError="Room is required" Class="mb-3"
                           AnchorOrigin="Origin.BottomCenter" ValueChanged="OnRoomChanged">
                    @foreach (var room in AvailableRooms)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)room.Id)">
                            @room.Name (Capacity: @room.Capacity)
                        </MudSelectItem>
                    }
                </MudSelect>
            }
            <MudDatePicker @bind-Date="_date" Label="Date" Required="true"
                           RequiredError="Date is required" Class="mb-3" />
            <MudTimePicker @bind-Time="_startTime" Label="Start Time" Required="true"
                           RequiredError="Start time is required" Class="mb-3" />
            <MudTimePicker @bind-Time="_endTime" Label="End Time" Required="true"
                           RequiredError="End time is required" Class="mb-3" />
        </MudForm>
        @if (_conflictWarning is not null)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-3">@_conflictWarning</MudAlert>
        }
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(!_isValid || _submitting)">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public List<LocationResponse> Locations { get; set; } = [];

    private MudForm _form = default!;
    private bool _isValid;
    private bool _submitting;
    private string? _error;
    private string? _conflictWarning;

    private Guid? _selectedLocationId;
    private Guid? _selectedRoomId;
    private DateTime? _date = DateTime.Today;
    private TimeSpan? _startTime = new(9, 0, 0);
    private TimeSpan? _endTime = new(10, 0, 0);

    private IEnumerable<RoomResponse> AvailableRooms =>
        Locations.FirstOrDefault(l => l.Id == _selectedLocationId)?.Rooms
            .Where(r => r.Status == RoomStatus.Enabled) ?? [];

    private void OnLocationChanged(Guid? locationId)
    {
        _selectedLocationId = locationId;
        _selectedRoomId = null;
        _conflictWarning = null;
    }

    private async Task OnRoomChanged(Guid? roomId)
    {
        _selectedRoomId = roomId;
        _conflictWarning = null;
        await CheckAvailability();
    }

    private async Task CheckAvailability()
    {
        if (!_selectedRoomId.HasValue || !_date.HasValue || !_startTime.HasValue || !_endTime.HasValue)
            return;

        try
        {
            var offset = TimeZoneInfo.Local.GetUtcOffset(DateTime.Now);
            var start = new DateTimeOffset(_date.Value.Add(_startTime.Value), offset);
            var end = new DateTimeOffset(_date.Value.Add(_endTime.Value), offset);
            var bookedSlots = await FacilityApi.GetRoomAvailabilityAsync(_selectedRoomId.Value, start, end);
            _conflictWarning = bookedSlots.Count > 0
                ? "This room has existing bookings during the selected time. The booking may fail."
                : null;
        }
        catch
        {
            // Non-fatal
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _submitting = true;
        _error = null;

        try
        {
            var offset = TimeZoneInfo.Local.GetUtcOffset(DateTime.Now);
            var start = new DateTimeOffset(_date!.Value.Add(_startTime!.Value), offset);
            var end = new DateTimeOffset(_date!.Value.Add(_endTime!.Value), offset);

            var request = new CreateBookingRequest(
                _selectedRoomId!.Value,
                _selectedLocationId!.Value,
                start,
                end,
                BookingReferenceType.Manual.ToString(),
                Guid.NewGuid());

            var response = await FacilityApi.CreateBookingAsync(request);
            if (response.IsSuccessStatusCode)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = $"Failed to create booking: {body}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to create booking: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
