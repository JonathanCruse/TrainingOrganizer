@page "/members"
@attribute [Authorize(Roles = "Trainer,Admin")]
@inject MemberApiClient MemberApi
@inject IDialogService DialogService

<PageTitle>Members</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Members</MudText>
    <AuthorizeView Roles="Admin">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenRegisterDialog">
            Register Member
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudStack Row="true" Spacing="2" Class="mb-4" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
    <MudTextField @bind-Value="_search" Label="Search name or email" Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true" Immediate="false" DebounceInterval="400"
                  TextChanged="OnSearchChanged" Style="min-width: 240px;" />
    <MudSelect T="RegistrationStatus?" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense"
               Value="_statusFilter" ValueChanged="OnStatusChanged" Clearable="true" Style="min-width: 160px;">
        @foreach (var s in Enum.GetValues<RegistrationStatus>())
        {
            <MudSelectItem T="RegistrationStatus?" Value="@s">@s</MudSelectItem>
        }
    </MudSelect>
    <MudSelect T="MemberRole?" Label="Role" Variant="Variant.Outlined" Margin="Margin.Dense"
               Value="_roleFilter" ValueChanged="OnRoleChanged" Clearable="true" Style="min-width: 140px;">
        @foreach (var r in Enum.GetValues<MemberRole>())
        {
            <MudSelectItem T="MemberRole?" Value="@r">@r</MudSelectItem>
        }
    </MudSelect>
    @if (HasActiveFilters)
    {
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilters">
            Clear filters
        </MudButton>
    }
</MudStack>

@if (HasActiveFilters)
{
    <MudStack Row="true" Spacing="1" Class="mb-3" Wrap="Wrap.Wrap">
        @if (!string.IsNullOrWhiteSpace(_search))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _search = null; _ = LoadMembers(); }">
                Search: @_search
            </MudChip>
        }
        @if (_statusFilter.HasValue)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _statusFilter = null; _ = LoadMembers(); }">
                Status: @_statusFilter
            </MudChip>
        }
        @if (_roleFilter.HasValue)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" OnClose="() => { _roleFilter = null; _ = LoadMembers(); }">
                Role: @_roleFilter
            </MudChip>
        }
    </MudStack>
}

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_members is null || _members.Count == 0)
{
    <MudAlert Severity="Severity.Info">No members found.</MudAlert>
}
else
{
    <MudTable Items="_members" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Roles</MudTh>
            <MudTh>Registered</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate Context="member">
            <MudTd DataLabel="Name">@member.FirstName @member.LastName</MudTd>
            <MudTd DataLabel="Email">@member.Email</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(member.Status)" Size="Size.Small">
                    @member.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Roles">
                @foreach (var role in member.Roles)
                {
                    <MudChip T="string" Size="Size.Small" Class="mr-1">@role</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Registered">@member.RegisteredAt.LocalDateTime.ToString("d")</MudTd>
            <MudTd DataLabel="Actions">
                <AuthorizeView Roles="Admin">
                    @if (member.Status == RegistrationStatus.Pending)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                                       Size="Size.Small" title="Approve"
                                       OnClick="@(() => ApproveMember(member.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                                       Size="Size.Small" title="Reject"
                                       OnClick="@(() => RejectMember(member.Id))" />
                    }
                    @if (member.Status == RegistrationStatus.Approved)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Warning"
                                       Size="Size.Small" title="Suspend"
                                       OnClick="@(() => SuspendMember(member.Id))" />
                    }
                    @if (member.Status == RegistrationStatus.Suspended)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Color="Color.Success"
                                       Size="Size.Small" title="Reinstate"
                                       OnClick="@(() => ReinstateMember(member.Id))" />
                    }
                </AuthorizeView>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<MemberResponse>? _members;
    private string? _error;
    private bool _loading = true;

    private string? _search;
    private RegistrationStatus? _statusFilter;
    private MemberRole? _roleFilter;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_search) || _statusFilter.HasValue || _roleFilter.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        _loading = true;
        _error = null;

        try
        {
            var result = await MemberApi.GetAllAsync(
                status: _statusFilter?.ToString(), search: _search, role: _roleFilter?.ToString());
            _members = result?.Items.ToList();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load members: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchChanged(string? value)
    {
        _search = value;
        await LoadMembers();
    }

    private async Task OnStatusChanged(RegistrationStatus? value)
    {
        _statusFilter = value;
        await LoadMembers();
    }

    private async Task OnRoleChanged(MemberRole? value)
    {
        _roleFilter = value;
        await LoadMembers();
    }

    private async Task ClearFilters()
    {
        _search = null;
        _statusFilter = null;
        _roleFilter = null;
        await LoadMembers();
    }

    private async Task OpenRegisterDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RegisterMemberDialog>(string.Empty, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadMembers();
        }
    }

    private async Task ApproveMember(Guid id)
    {
        try
        {
            await MemberApi.ApproveAsync(id);
            await LoadMembers();
        }
        catch (Exception ex)
        {
            _error = $"Failed to approve member: {ex.Message}";
        }
    }

    private async Task RejectMember(Guid id)
    {
        try
        {
            await MemberApi.RejectAsync(id, new RejectMemberRequest("Rejected by admin"));
            await LoadMembers();
        }
        catch (Exception ex)
        {
            _error = $"Failed to reject member: {ex.Message}";
        }
    }

    private async Task SuspendMember(Guid id)
    {
        try
        {
            await MemberApi.SuspendAsync(id, new SuspendMemberRequest("Suspended by admin"));
            await LoadMembers();
        }
        catch (Exception ex)
        {
            _error = $"Failed to suspend member: {ex.Message}";
        }
    }

    private async Task ReinstateMember(Guid id)
    {
        try
        {
            await MemberApi.ReinstateAsync(id);
            await LoadMembers();
        }
        catch (Exception ex)
        {
            _error = $"Failed to reinstate member: {ex.Message}";
        }
    }

    private static Color GetStatusColor(RegistrationStatus status) => status switch
    {
        RegistrationStatus.Approved => Color.Success,
        RegistrationStatus.Pending => Color.Warning,
        RegistrationStatus.Rejected => Color.Error,
        RegistrationStatus.Suspended => Color.Dark,
        _ => Color.Default
    };
}
